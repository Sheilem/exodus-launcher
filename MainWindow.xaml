<Window x:Class="ExodusLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ExodusLauncher"
        Title="Exodus Launcher" Height="620" Width="1000"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StrVis"/>
        <DataTemplate x:Key="FeedCard">
            <Border CornerRadius="11" Background="#22000000" Padding="15,12" Margin="0,0,0,11"
                    BorderBrush="{StaticResource PanelStroke}" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="{StaticResource Accent}" CornerRadius="5" Padding="7,2"
                                Visibility="{Binding Tag, Converter={StaticResource StrVis}}">
                            <TextBlock Text="{Binding Tag}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="{Binding Date}" Foreground="{StaticResource TextMuted}" FontSize="11"
                                   VerticalAlignment="Center" Margin="9,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Body}" Foreground="{StaticResource TextMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,5,0,0" LineHeight="19"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="12" CornerRadius="16" Background="{StaticResource WindowGrad}"
            BorderBrush="{StaticResource PanelStroke}" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="28" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="96"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" x:Name="TitleBar" Background="Transparent" MouseLeftButtonDown="TitleBar_Drag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentGrad}" Margin="0,0,9,0"/>
                    <TextBlock Text="EXODUS" Foreground="{StaticResource AccentBright}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="LAUNCHER" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="14" Margin="8,0,0,0"/>
                    <Image Source="/Assets/snail.png" Width="22" Height="22" Margin="10,0,0,0"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="MinBtn" Style="{StaticResource CaptionButton}" Content="&#x2013;" Click="Min_Click"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource CaptionButton}" Content="&#x2715;" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- BODY -->
            <Grid Grid.Row="1" Margin="18,4,18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: server status + nav + mascot -->
                <Border Grid.Column="0" CornerRadius="14" Background="{StaticResource Panel}"
                        BorderBrush="{StaticResource PanelStroke}" BorderThickness="1" Padding="18">
                    <DockPanel>
                        <!-- status card -->
                        <Border DockPanel.Dock="Top" CornerRadius="12" Background="#26000000" Padding="16,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="StatusDot" Width="13" Height="13" Fill="{StaticResource Online}" VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect x:Name="StatusGlow" Color="#FF45D67E" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock x:Name="StatusText" Text="CHECKING…" Foreground="{StaticResource TextPrimary}"
                                               FontSize="17" FontWeight="Bold" Margin="11,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="UptimeText" Foreground="{StaticResource TextMuted}" FontSize="13" Margin="2,10,0,0"/>
                                <TextBlock x:Name="PlayersText" Foreground="{StaticResource TextMuted}" FontSize="13" Margin="2,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- nav pinned to bottom -->
                        <StackPanel DockPanel.Dock="Bottom">
                            <Button Style="{StaticResource CardButton}" Click="Settings_Click" Margin="0,0,0,10"
                                    Content="⚙   Game Settings"/>
                            <Button Style="{StaticResource GhostButton}" Click="Discord_Click" Content="💬   Discord"/>
                            <Button Style="{StaticResource GhostButton}" Click="Forum_Click" Content="🌐   Forums"/>
                            <TextBlock x:Name="VersionLabel" Foreground="{StaticResource Unknown}" FontSize="11"
                                       Margin="12,6,0,0" Text="client —"/>
                        </StackPanel>

                        <!-- mascot fills the middle -->
                        <Image Source="/Assets/orangemushroom2.png" Width="96" Height="96" Margin="0,8"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- RIGHT: news / patch notes tabs -->
                <Border Grid.Column="1" Margin="16,0,0,0" CornerRadius="14" Background="{StaticResource Panel}"
                        BorderBrush="{StaticResource PanelStroke}" BorderThickness="1" Padding="20,14">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="NewsTab" Style="{StaticResource TabButton}" Content="NEWS" Click="NewsTab_Click"/>
                                <Button x:Name="PatchTab" Style="{StaticResource TabButton}" Content="PATCH NOTES" Margin="20,0,0,0" Click="PatchTab_Click"/>
                            </StackPanel>
                            <Image Source="/Assets/slime.png" Width="30" Height="30" HorizontalAlignment="Right"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Grid>

                        <Grid>
                            <ScrollViewer x:Name="NewsScroller" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                                <ItemsControl x:Name="NewsList" ItemTemplate="{StaticResource FeedCard}"/>
                            </ScrollViewer>
                            <ScrollViewer x:Name="PatchScroller" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0" Visibility="Collapsed">
                                <ItemsControl x:Name="PatchList" ItemTemplate="{StaticResource FeedCard}"/>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- BOTTOM BAR -->
            <Grid Grid.Row="2" Margin="18,12,18,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="2,0,24,0">
                    <Grid Margin="0,0,0,7">
                        <TextBlock x:Name="PhaseText" Text="Starting…" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="DetailText" Text="" Foreground="{StaticResource TextMuted}" FontSize="12"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="360"/>
                    </Grid>
                    <ProgressBar x:Name="Progress" Style="{StaticResource SlimBar}" Minimum="0" Maximum="1" Value="0"/>
                </StackPanel>

                <Button x:Name="PlayBtn" Grid.Column="1" Style="{StaticResource PlayButton}"
                        Content="CHECKING…" IsEnabled="False" Click="Play_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>
